cd /Users/aishwaryadas/deloitte-challenge-2026/insurance-model

cat > .gitignore << 'EOF'
# Python cache
__pycache__/
*.pyc
*.pyo
.Python

# Mac system files
.DS_Store
**/.DS_Store

# Jupyter checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Virtual environment
.venv/

# Large data files (too big for GitHub)
data/raw/*.csv
data/processed/*.csv
EOF